# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://plum_admin:password123@db:5432/product_verification
DATABASE_ECHO=false

# ─── Redis / Cache ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── LLM Provider ──────────────────────────────────────
# Options: openai, anthropic, google, mock
LLM_PROVIDER=mock
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
ANTHROPIC_BASE_URL=baseurl
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# GOOGLE_API_KEY=xxx
# GOOGLE_MODEL=gemini-2.0-flash

# ─── Document Processing ───────────────────────────────
# Options: hybrid, docling_only, vision_only
DOCUMENT_PROCESSOR=hybrid
# For Docling OCR backend: easyocr, tesseract, rapidocr
DOCLING_OCR_ENGINE=easyocr

# ─── Storage ───────────────────────────────────────────
# Options: local, minio, s3
STORAGE_PROVIDER=local
STORAGE_PATH=/workspace/backend/uploads
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# S3_BUCKET=plum-claims-docs
# AWS_REGION=ap-south-1

# ─── Observability ─────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=plum-claims
ENABLE_TRACING=true
ENABLE_METRICS=true

# ─── Application ───────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
API_PREFIX=/api/v1

# ─── Security ──────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
RATE_LIMIT_PER_MINUTE=60
